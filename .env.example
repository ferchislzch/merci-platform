# MERCI Backend — Variables de entorno
# Copia este archivo como .env y llena los valores reales 

#  SERVIDOR 
NODE_ENV=development
PORT=3000

#  BASE DE DATOS 
# Conexión a PostgreSQL. Cada quien usa su usuario/password local.
DATABASE_URL=postgresql://postgres:3310@localhost:5432/merci

# JWT 
# Generar valores aleatorios largos para desarrollo.
# En producción, valores distintos y secretos reales.
JWT_SECRET=merci_dev_secret_cambiar
JWT_EXPIRES_IN=8h
JWT_REFRESH_SECRET=merci_refresh_cambiar
JWT_REFRESH_EXPIRES_IN=7d

#  OPENAI (cubre LLM GPT-4o + Whisper STT + TTS)
# Una sola key de la organización MERCI cubre los tres servicios
OPENAI_API_KEY=sk-placeholder
OPENAI_ORG_ID=org-placeholder

#  GOOGLE GEMINI (LLM) 
# Obtener en aistudio.google.com
GOOGLE_GEMINI_API_KEY=placeholder

# GOOGLE CLOUD SPEECH-TO-TEXT (STT) 
# Requiere proyecto GCP separado + Service Account JSON
# El archivo JSON va en /secrets (NO se sube a Git)
GOOGLE_CLOUD_PROJECT_ID=placeholder
GOOGLE_APPLICATION_CREDENTIALS=./secrets/google-service-account.json

# ELEVENLABS (TTS) 
# Obtener en elevenlabs.io
ELEVENLABS_API_KEY=placeholder

# WEBSOCKET / CORS
# URL del frontend que puede conectarse
WS_CORS_ORIGIN=http://localhost:5173

# RATE LIMITING
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

#  WORKER (jobs_async) 
WORKER_POLL_INTERVAL_MS=5000
WORKER_BATCH_SIZE=5

# PRECIOS DE REFERENCIA POR PROVEEDOR (USD)
# Usados para calcular costo_estimado en consumo_ia
# Actualizar si los proveedores cambian precios

# OpenAI GPT-4o — por millón de tokens
PRICE_OPENAI_LLM_INPUT_PER_1M=2.50
PRICE_OPENAI_LLM_OUTPUT_PER_1M=10.00

# OpenAI Whisper — por minuto de audio
PRICE_OPENAI_STT_PER_MINUTE=0.006

# OpenAI TTS — por millón de caracteres
PRICE_OPENAI_TTS_PER_1M_CHARS=15.00

# Google Gemini 1.5 Flash — por millón de tokens
PRICE_GOOGLE_LLM_INPUT_PER_1M=0.075
PRICE_GOOGLE_LLM_OUTPUT_PER_1M=0.30

# Google STT — por minuto de audio
PRICE_GOOGLE_STT_PER_MINUTE=0.016

# ElevenLabs — por millón de caracteres
PRICE_ELEVENLABS_TTS_PER_1M_CHARS=180.00

# MARGEN MERCI
# % que MERCI agrega sobre el costo del proveedor (Modelo B)
MERCI_MARGIN_PERCENTAGE=30